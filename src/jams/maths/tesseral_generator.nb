       RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "is", " ", 
      "a", " ", "unit", " ", 
      RowBox[{"vector", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TesseralHarmonicUnitVector", "[", 
     RowBox[{"l_Integer", ",", "m_Integer", ",", "x_", ",", "y_", ",", "z_"}],
      "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"TesseralHarmonic", "[", 
       RowBox[{
       "l", ",", " ", "m", ",", " ", "x", ",", " ", "y", ",", " ", "z"}], 
       "]"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}], "+", 
          RowBox[{"z", "^", "2"}]}], "==", "1"}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Returns", " ", "the", " ", "gradient", " ", "of", " ", "the", " ", 
      "tesseral", " ", "harmonic", " ", 
      SubscriptBox["Z", 
       RowBox[{"l", ",", "m"}]], " ", "in", " ", "Cartesian", " ", 
      "coordinates"}], ",", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "where", " ", 
      "the", " ", "vector", " ", "described", " ", "by", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], " ", "is", " ", 
      "a", " ", "unit", " ", 
      RowBox[{"vector", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DTesseralHarmonicUnitVector", "[", 
     RowBox[{"l_Integer", ",", "m_Integer", ",", "x_", ",", "y_", ",", "z_"}],
      "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Grad", "[", 
       RowBox[{
        RowBox[{"TesseralHarmonic", "[", 
         RowBox[{
         "l", ",", " ", "m", ",", " ", "x", ",", " ", "y", ",", " ", "z"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "\"\<Cartesian\>\""}],
        "]"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}], "+", 
          RowBox[{"z", "^", "2"}]}], "==", "1"}], "}"}]}]}], "]"}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"monicCartesianBasis", "[", 
     RowBox[{"l_", ",", "m_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"expr", ",", "rules", ",", "lead"}], "}"}], ",", 
      RowBox[{
       RowBox[{"expr", "=", 
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"4", " ", 
            RowBox[{"Pi", "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", "l"}], "+", "1"}], ")"}]}]}], "]"}], "*", 
          RowBox[{"TesseralHarmonicUnitVector", "[", 
           RowBox[{"l", ",", "m", ",", "x", ",", "y", ",", "z"}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rules", "=", 
        RowBox[{"CoefficientRules", "[", 
         RowBox[{"expr", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"lead", "=", 
        RowBox[{"First", "@", 
         RowBox[{"Select", "[", 
          RowBox[{"rules", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Total", "[", 
              RowBox[{"First", "[", "#", "]"}], "]"}], ">", "0"}], "&"}]}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Expand", "[", 
        RowBox[{"expr", "/", 
         RowBox[{"Last", "[", "lead", "]"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"name", "[", 
      RowBox[{"l_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"\"\<tesseral_monic_cartesian_l\>\"", "<>", 
      RowBox[{"ToString", "[", "l", "]"}], "<>", "\"\<_\>\"", "<>", 
      RowBox[{"Which", "[", 
       RowBox[{
        RowBox[{"m", "<", "0"}], ",", 
        RowBox[{"\"\<m\>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"Abs", "[", "m", "]"}], "]"}]}], ",", 
        RowBox[{"m", ">", "0"}], ",", 
        RowBox[{"\"\<p\>\"", "<>", 
         RowBox[{"ToString", "[", "m", "]"}]}], ",", "True", 
        ",", "\"\<0\>\""}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"count", "=", "0"}], ";", 
      RowBox[{"l", "=", "2"}]}], ",", 
     RowBox[{"l", "<=", "6"}], ",", 
     RowBox[{"l", "+=", "2"}], ",", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"-", "l"}]}], ",", 
       RowBox[{"m", "<=", "l"}], ",", 
       RowBox[{"m", "++"}], ",", 
       RowBox[{
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<// Z_{\>\"", ",", 
          RowBox[{"ToString", "[", "l", "]"}], ",", "\"\<,\>\"", ",", 
          RowBox[{"ToString", "[", "m", "]"}], ",", "\"\<} = \>\"", ",", 
          RowBox[{"ToString", "[", 
           RowBox[{
            RowBox[{"monicCartesianBasis", "[", 
             RowBox[{"l", ",", "m"}], "]"}], ",", "InputForm"}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<template <typename T>\\n\>\""}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<constexpr T \>\"", ",", 
          RowBox[{"name", "[", 
           RowBox[{"l", ",", "m"}], "]"}], 
          ",", "\"\<(T x, T y, T z) {\\n\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", 
          ",", "\"\<  static_assert(std::is_floating_point_v<T>, \\\"T must \
be a floating-point type\\\");\\n\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<  return \>\"", ",", 
          RowBox[{"ToRationalCFormString", "[", 
           RowBox[{
            RowBox[{"monicCartesianBasis", "[", 
             RowBox[{"l", ",", "m"}], "]"}], ",", "\"\<T\>\""}], "]"}], 
          ",", "\"\<;\\n\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<}\\n\\n\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"count", "++"}], ";"}]}], "]"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"gradName", "[", 
      RowBox[{"l_", ",", "m_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"name", "[", 
       RowBox[{"l", ",", "m"}], "]"}], "<>", "\"\<_grad\>\""}]}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"monicCartesianBasisGrad", "[", 
     RowBox[{"l_", ",", "m_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "q", "}"}], ",", 
      RowBox[{
       RowBox[{"q", "=", 
        RowBox[{"monicCartesianBasis", "[", 
         RowBox[{"l", ",", "m"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Expand", "/@", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{"q", ",", "x"}], "]"}], ",", 
          RowBox[{"D", "[", 
           RowBox[{"q", ",", "y"}], "]"}], ",", 
          RowBox[{"D", "[", 
           RowBox[{"q", ",", "z"}], "]"}]}], "}"}]}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"count", "=", "0"}], ";", 
      RowBox[{"l", "=", "2"}]}], ",", 
     RowBox[{"l", "<=", "6"}], ",", 
     RowBox[{"l", "+=", "2"}], ",", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"-", "l"}]}], ",", 
       RowBox[{"m", "<=", "l"}], ",", 
       RowBox[{"m", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<// grad Z_{\>\"", ",", 
          RowBox[{"ToString", "[", "l", "]"}], ",", "\"\<,\>\"", ",", 
          RowBox[{"ToString", "[", "m", "]"}], ",", "\"\<} = \>\"", ",", 
          RowBox[{"ToString", "[", 
           RowBox[{
            RowBox[{"monicCartesianBasisGrad", "[", 
             RowBox[{"l", ",", "m"}], "]"}], ",", "InputForm"}], "]"}], 
          ",", "\"\<\\n\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<template <typename T>\\n\>\""}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<constexpr std::array<T, 3> \>\"",
           ",", 
          RowBox[{"gradName", "[", 
           RowBox[{"l", ",", "m"}], "]"}], 
          ",", "\"\<(T x, T y, T z) {\\n\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", 
          ",", "\"\<  static_assert(std::is_floating_point_v<T>, \\\"T must \
be a floating-point type\\\");\\n\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", 
          ",", "\"\<  return std::array<T, 3>{\\n\>\"", ",", 
          "\[IndentingNewLine]", "\"\<    \>\"", ",", 
          RowBox[{"ToRationalCFormString", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"monicCartesianBasisGrad", "[", 
              RowBox[{"l", ",", "m"}], "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<T\>\""}], "]"}], 
          ",", "\"\<,\\n\>\"", ",", "\[IndentingNewLine]", "\"\<    \>\"", ",", 
          RowBox[{"ToRationalCFormString", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"monicCartesianBasisGrad", "[", 
              RowBox[{"l", ",", "m"}], "]"}], "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", "\"\<T\>\""}], "]"}], 
          ",", "\"\<,\\n\>\"", ",", "\[IndentingNewLine]", "\"\<    \>\"", ",", 
          RowBox[{"ToRationalCFormString", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"monicCartesianBasisGrad", "[", 
              RowBox[{"l", ",", "m"}], "]"}], "[", 
             RowBox[{"[", "3", "]"}], "]"}], ",", "\"\<T\>\""}], "]"}], 
          ",", "\"\<\\n\>\"", ",", "\[IndentingNewLine]", "\"\<  };\\n\>\""}],
          "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"\"\<stdout\>\"", ",", "\"\<}\\n\\n\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"count", "++"}], ";"}]}], "]"}]}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
